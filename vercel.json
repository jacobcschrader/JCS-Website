{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 14 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/architecture",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/films",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/design",
      "destination": "/services",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/book",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/proposals/:slug([a-z0-9-]+)",
      "destination": "/proposal"
    }
  ]
}
